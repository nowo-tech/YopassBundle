<!DOCTYPE html>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ 'yopass.public.title'|trans({}, 'NowoYopassBundle') }}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.0.0-beta20/dist/css/tabler.min.css">
    <style>body { background: #f6f8fb; }</style>
</head>
<body class="layout-fluid">
<div class="page page-center">
    <div class="container container-tight py-4">
        <div class="card card-md shadow-sm">
            <div class="card-body"
                 data-controller="nowo-share-reveal"
                 data-nowo-share-reveal-consume-url-value="{{ path(routes.public_consume.name, { id: share.id }) }}"
                 data-nowo-share-reveal-share-id-value="{{ share.id }}"
                 data-nowo-share-reveal-mode-value="{{ decryption_mode }}"
                 data-nowo-share-reveal-errors-value="{{ {
                     'KEY_REQUIRED': 'yopass.public.key_required'|trans({}, 'NowoYopassBundle'),
                     'PASSWORD_REQUIRED': 'yopass.public.password_required'|trans({}, 'NowoYopassBundle'),
                     'INVALID_KEY': 'yopass.public.invalid_key'|trans({}, 'NowoYopassBundle'),
                     'expired': 'yopass.public.unavailable'|trans({}, 'NowoYopassBundle'),
                     'revoked': 'yopass.public.unavailable'|trans({}, 'NowoYopassBundle'),
                     'consumed': 'yopass.public.unavailable'|trans({}, 'NowoYopassBundle'),
                 }|json_encode|e('html_attr') }}">
                <h1 class="h2 mb-3">{{ 'yopass.public.title'|trans({}, 'NowoYopassBundle') }}</h1>

                {% if not share.isAvailable %}
                    <div class="alert alert-warning mb-0">{{ 'yopass.public.unavailable'|trans({}, 'NowoYopassBundle') }}</div>
                {% else %}
                    <p class="text-secondary">{{ 'yopass.public.intro'|trans({}, 'NowoYopassBundle') }}</p>
                    <p class="text-secondary small">{{ 'yopass.public.e2e_notice'|trans({}, 'NowoYopassBundle') }}</p>

                    {% if decryption_mode == 'password' %}
                        <p class="text-secondary small d-none mb-3" data-nowo-share-reveal-target="passwordFromLinkHint">
                            {{ 'yopass.public.password_from_link'|trans({}, 'NowoYopassBundle') }}
                        </p>
                        <div class="mb-3" data-nowo-share-reveal-target="passwordPanel">
                            <label class="form-label" for="share-password">{{ 'yopass.public.password_field'|trans({}, 'NowoYopassBundle') }}</label>
                            <input type="password" id="share-password" class="form-control" data-nowo-share-reveal-target="password" autocomplete="off">
                        </div>
                    {% else %}
                        <p class="text-secondary small d-none mb-3" data-nowo-share-reveal-target="keyFromLinkHint">
                            {{ 'yopass.public.key_from_link'|trans({}, 'NowoYopassBundle') }}
                        </p>
                        <div class="mb-3 d-none" data-nowo-share-reveal-target="keyPanel">
                            <label class="form-label" for="share-key">{{ 'yopass.public.key_field'|trans({}, 'NowoYopassBundle') }}</label>
                            <input type="text" id="share-key" class="form-control" data-nowo-share-reveal-target="key" autocomplete="off">
                            <p class="text-secondary small mt-1 mb-0">{{ 'yopass.public.key_help'|trans({}, 'NowoYopassBundle') }}</p>
                        </div>
                    {% endif %}

                    <button type="button" class="btn btn-primary" data-action="nowo-share-reveal#reveal">
                        {{ 'yopass.public.reveal'|trans({}, 'NowoYopassBundle') }}
                    </button>

                    <pre class="alert alert-success mt-3 mb-0 d-none text-wrap" data-nowo-share-reveal-target="output"></pre>
                    <a href="#" class="btn btn-outline-primary mt-3 d-none" download data-nowo-share-reveal-target="downloadLink"></a>
                    <div class="alert alert-danger mt-3 d-none" data-nowo-share-reveal-target="error"></div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
<script type="module" src="{{ asset('js/yopass.js', 'nowo_yopass') }}"></script>
</body>
</html>
