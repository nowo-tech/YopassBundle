# APP_ENV: Symfony environment. Demos run in `dev`.
APP_ENV=dev

# APP_DEBUG: enable Symfony debug in demos.
APP_DEBUG=true

# APP_SECRET: local-only app secret for cookies/tokens.
APP_SECRET=change_this_secret_key_to_a_random_value

# PORT: host port exposed by the demo web server.
PORT=8022

# DEFAULT_URI: URL opened in browser after startup.
DEFAULT_URI=http://localhost:8022

# MYSQL_ROOT_PASSWORD: local root password for the MySQL container.
MYSQL_ROOT_PASSWORD=root

# MYSQL_DATABASE: schema used by the demo application.
MYSQL_DATABASE=yopass_demo

# MYSQL_USER: application user for DB access.
MYSQL_USER=demo

# MYSQL_PASSWORD: application password for DB access.
MYSQL_PASSWORD=demo

# DATABASE_URL: Doctrine DSN using the Docker service hostname.
DATABASE_URL=mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@mysql:3306/${MYSQL_DATABASE}?serverVersion=8.0.32&charset=utf8mb4

# Yopass local file storage (gitignored dir under var/; not web-accessible).
# YOPASS_LOCAL_STORAGE_DIR=%kernel.project_dir%/var/yopass-storage
# YOPASS_LOCAL_MAX_FILE_BYTES=524288
# Optional at-rest encryption (base64-encoded 32-byte key). Empty = E2E ciphertext only.
# Generate: php -r 'echo base64_encode(random_bytes(32)), PHP_EOL;'
# YOPASS_LOCAL_STORAGE_KEY=
