# PHPUnit / test environment (versioned). Do not commit .env or .env.dev.

# KERNEL_CLASS: PHPUnit kernel bootstrap class.
KERNEL_CLASS='App\Kernel'

# APP_SECRET: fixed secret for deterministic tests.
APP_SECRET=test_secret

# DATABASE_URL: isolated SQLite database for demo tests.
DATABASE_URL="sqlite:///%kernel.project_dir%/var/test.db"
