# AWS S3 example for Yopass file shares (copy to .env.s3.local — never commit secrets)
#
# Set YOPASS_USE_S3=1 in .env after merging these vars to switch from local disk storage.
#
# Bucket requirements (see docs/examples/S3.md):
# - Block all public access enabled
# - Default encryption: SSE-KMS (recommended) or SSE-S3
# - No bucket policy granting public read/write

AWS_REGION=eu-west-1
YOPASS_USE_S3=1
YOPASS_S3_BUCKET=
YOPASS_S3_KMS_KEY_ID=
YOPASS_S3_KEY_PREFIX=yopass-shares
YOPASS_S3_MAX_FILE_BYTES=524288

# IAM user/role with least privilege: s3:PutObject, s3:GetObject, s3:DeleteObject (optional), s3:HeadBucket on the bucket/prefix only
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
